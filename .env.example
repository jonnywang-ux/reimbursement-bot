# Slack — api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack — api.slack.com/apps → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-here

# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Dropbox Sign (HelloSign) — app.hellosign.com → Settings → Integrations → API
HELLOSIGN_API_KEY=your-hellosign-api-key-here

# Signing chain — 4 signers in order
SIGNER_1_EMAIL=signer1@example.com
SIGNER_1_NAME=Signer One
SIGNER_2_EMAIL=signer2@example.com
SIGNER_2_NAME=Signer Two
SIGNER_3_EMAIL=signer3@example.com
SIGNER_3_NAME=Signer Three
SIGNER_4_EMAIL=signer4@example.com
SIGNER_4_NAME=Signer Four

# Server — Railway overrides PORT automatically
PORT=3000
